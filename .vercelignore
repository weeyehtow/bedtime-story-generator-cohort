# Hide everything except the static frontend from Vercel.
# Without this, Vercel auto-detects requirements.txt + app/main.py at the master
# root and tries to deploy the Python backend as a serverless function, which
# fails with FUNCTION_INVOCATION_FAILED — our backend belongs on Render, not Vercel.
#
# Vercel's `outputDirectory: frontend` in vercel.json tells it where the static
# output lives; .vercelignore tells it what NOT to consider for build / function
# detection in the first place. Belt-and-braces.

# Backend (deployed to Render, not Vercel)
app/
sql/
requirements.txt
Procfile
render.yaml

# Curriculum + maintainer artifacts (not needed at deploy time)
dist/
docs/
slides/
scripts/
.module-drafts/
INSTRUCTOR_GUIDE.md
WSL2_VALIDATOR_BRIEF.md
bedtime_story_generator_prd_v1.md
AGENTS.md
README.md
.env.example

# Local dev artifacts
venv/
__pycache__/
.pytest_cache/
.DS_Store

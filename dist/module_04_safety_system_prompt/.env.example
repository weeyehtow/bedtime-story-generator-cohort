# Bedtime Story Generator — environment-variable contract.
# Copy this file to .env and fill in any TBD values. .env is .gitignore'd.

# Module 0 (V1 baseline) carried Postgres + Ollama. Module 1 drops Ollama and
# swaps in Gemini. Postgres carries through V1 — Module 6 swaps the V1 `interactions`
# table for a `stories` table so a child can ask to re-hear yesterday's story.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_question_log
GEMINI_API_KEY=your-google-ai-studio-key-here

# Module 7 — Vercel + Render deployment
# BACKEND_URL=https://your-render-app.onrender.com
